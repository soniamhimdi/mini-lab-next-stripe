# Cle secrete Stripe — NE JAMAIS exposer cote client (commence par sk_test_ en mode test)
STRIPE_SECRET_KEY=sk_test_votre_cle_secrete

# Cle publique Stripe — peut etre utilisee cote navigateur (commence par pk_test_ en mode test)
# Le prefixe NEXT_PUBLIC_ permet a Next.js d’envoyer cette variable au client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_votre_cle_publique

# URL de base de l’application — utilisee cote serveur pour construire les URLs
# de redirection Stripe
APP_URL=http://localhost:3000

# Meme URL mais accessible cote client grace au prefixe NEXT_PUBLIC_
NEXT_PUBLIC_APP_URL=http://localhost:3000